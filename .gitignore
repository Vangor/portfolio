# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

/out/

# production
/build
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — use .env.example for var reference; never commit real env files
.env
.env.*
!.env.example
.env.local
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo

# Filesystem task docs removed; vault/knowledge DB is sole source (2026-05-30)
/tasks/
